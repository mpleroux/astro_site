---
import Menu from "./Menu.astro";
import Navigation from "./Navigation.astro";
import ThemeIcon from "./ThemeIcon.astro";
---

<header class="relative mb-8">
  <div
    class="flex items-center justify-between px-4 py-3 sm:mb-6 sm:justify-center sm:gap-4 sm:px-0">
    <ThemeIcon />
    <div class="hidden h-6 w-px bg-gray-400 sm:block dark:bg-gray-500"></div>
    <Navigation />
    <Menu />
  </div>
</header>
