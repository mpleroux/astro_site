---
const currentPath = Astro.url.pathname;

const links = [
  { href: "/", label: "Home" },
  { href: "/about", label: "About" },
  { href: "/blog", label: "Blog" },
  { href: "/tags", label: "Tags" },
];

function isActive(href: string): boolean {
  if (href === "/") return currentPath === "/";
  return currentPath === href || currentPath.startsWith(href);
}
---

<div
  id="main-menu"
  class="absolute top-full right-0 left-0 z-50 hidden w-full bg-gray-200 sm:static sm:flex sm:w-auto sm:items-center sm:bg-transparent dark:bg-gray-700"
>
  {
    links.map(({ href, label }) => (
      <a
        href={href}
        class:list={[
          "block px-4 py-3 text-page-text no-underline transition-colors",
          "hover:bg-gray-300 dark:hover:bg-gray-600",
          "sm:rounded sm:px-3 sm:py-1",
          isActive(href) ? "bg-gray-400 dark:bg-gray-500" : "",
        ]}
      >
        {label}
      </a>
    ))
  }
</div>
