---
import BaseLayout from "./BaseLayout.astro";

const { frontmatter } = Astro.props;

function formatDate(date: Date): string {
  const d = new Date(date);
  return `${d.getFullYear()} ${d.toLocaleDateString("en-US", { month: "long" })} ${d.getDate()}`;
}
---

<BaseLayout>
  <!-- {
    frontmatter.description && (
      <p>
        <em>{frontmatter.description}</em>
      </p>
    )
  } -->

  <p>
    <a class="text-faded" href="/blog"
      ><span aria-hidden="true">&larr;</span> Blog</a
    >
  </p>

  <h1 class="hidden" aria-hidden="true">Blog Post</h1>

  <p class="text-meta mb-1 font-semibold uppercase">
    {formatDate(frontmatter.pubDate)}
  </p>

  <h2>{frontmatter.title}</h2>

  <!-- {
    frontmatter.image && (
      <img
        src={frontmatter.image.url}
        width="300"
        alt={frontmatter.image.alt}
      />
    )
  } -->

  <slot />

  <div class="flex flex-wrap text-xs">
    Tags:
    {
      frontmatter.tags.map((tag: string) => (
        <span class="pl-1">
          <a href={`/tags/${tag}`}>{tag}</a>
        </span>
      ))
    }
  </div>
</BaseLayout>
