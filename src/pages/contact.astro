---
import BaseLayout from "../layouts/BaseLayout.astro";

const pageTitle = "Contact";
---

<BaseLayout pageTitle={pageTitle}>
  <section class="not-content rounded-3xl">
    <p>Say hello!</p>

    <form
      action="https://usebasin.com/f/1dc0b37f9a47"
      method="POST"
      id="contact-form"
      name="contact form"
      class="flex flex-col gap-3">
      <input type="hidden" name="form-name" value="contact" />
      <div>
        <label for="contact-name" class="mb-1 block">Name</label>
        <input
          type="text"
          class="form-input"
          name="name"
          id="contact-name"
          required
        />
      </div>

      <!-- Honeypot field to catch bots. Purposefully mispelled "email" as "emai" to better trick bots -->
      <label for="emai" class="sr-only" aria-hidden="true">Real users skip this field</label>
      <input id="emai" type="text" name="emai" class="sr-only" tabindex="-1" aria-hidden="true" />

      <div>
        <label for="contact-email" class="mb-1 block">Email</label>
        <input
          type="email"
          class="form-input"
          name="email"
          id="contact-email"
          inputmode="email"
          required
        />
      </div>

      <div class="mb-2">
        <label for="contact-message" class="mb-1 block">Message</label>
        <textarea
          name="message"
          class="form-input"
          id="contact-message"
          rows="4"
          required></textarea>
      </div>

      <button
        type="submit"
        class="focus-visible:ring-opacity-50 flex items-center justify-center gap-2 rounded-md bg-button p-2.5 text-white transition hover:bg-button-hover focus:outline-none focus-visible:ring-2 focus-visible:ring-button-hover">
        <!-- your loading SVG here with id="form-loading" -->
        <svg
          id="form-loading"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
          class="icon icon-tabler icons-tabler-outline icon-tabler-loader-2 hidden size-5 animate-spin">
          <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
          <path d="M12 3a9 9 0 1 0 9 9"></path>
        </svg>
        Submit
      </button>
    </form>

    <!-- message send success feedback -->
    <div
      id="form-good-feedback"
      role="status"
      aria-live="polite"
      aria-hidden="true"
      class="invisible fixed bottom-4 z-10 mx-auto flex rounded-lg bg-green-200 p-0 text-green-800 opacity-0 transition duration-300">
      <div class="px-4 pt-4 text-center">
        <p class="m-0">Message sent successfully! I will get back to you.</p>
      </div>
    </div>

    <!-- message send fail feedback -->
    <div
      id="form-bad-feedback"
      role="alert"
      aria-live="assertive"
      aria-hidden="true"
      class="invisible fixed bottom-4 z-10 mx-auto flex rounded-lg bg-red-200 p-0 text-red-800 opacity-0 transition duration-300">
      <div class="px-4 pt-4 text-center">
        <p class="m-0">
          Something went wrong. Please try again or contact me by email.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // from https://cosmicthemes.com/blog/astro-effective-contact-form/
  //
  // handle the form submission
  var xhr = new XMLHttpRequest();

  // only one contact form supported per page
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const formLoadingIndicator = document.getElementById("form-loading");
  const formGoodFeedback = document.getElementById("form-good-feedback");
  const formBadFeedback = document.getElementById("form-bad-feedback");

  const handleFormSubmission = (event: Event) => {
    // prevent page from reloading
    event.preventDefault();

    // show loading indicator
    formLoadingIndicator?.classList.remove("hidden");

    // get form data
    const formData = new FormData(form);

    // create POST request to the form action attribute
    xhr.open("POST", form.action, true);

    // make sure we receive json back
    xhr.setRequestHeader("Accept", "application/json");

    // SEND IT!
    xhr.send(formData);

    // once we get a response...
    xhr.onload = function () {
      formLoadingIndicator?.classList.add("hidden");
      const response = JSON.parse(xhr.response);

      if (xhr.status === 200) {
        // The request was successful
        console.log("Form submitted successfully.");
        // reset form on successful email send
        form?.reset();

        if (formGoodFeedback) {
          formGoodFeedback.classList.remove("invisible");
          formGoodFeedback.classList.add("opacity-100");
          formGoodFeedback.setAttribute("aria-hidden", "false");

          // reset form feedback after a few seconds
          setTimeout(() => {
            formGoodFeedback.classList.remove("opacity-100");

            setTimeout(() => {
              formGoodFeedback.classList.add("invisible");
              formGoodFeedback.setAttribute("aria-hidden", "true");
            }, 300);
          }, 5000);
        }
      } else {
        const message = "Form submission failed with error: " + response.error;
        console.log(message);
        // The request failed
        if (formBadFeedback) {
          formBadFeedback.classList.remove("invisible");
          formBadFeedback.classList.add("opacity-100");
          formBadFeedback.setAttribute("aria-hidden", "false");

          // reset form feedback after a few seconds
          setTimeout(() => {
            formBadFeedback.classList.remove("opacity-100");

            setTimeout(() => {
              formBadFeedback.classList.add("invisible");
              formBadFeedback.setAttribute("aria-hidden", "true");
            }, 300);
          }, 7000);
        }
      }
    };
  };

  form?.addEventListener("submit", handleFormSubmission, true);
</script>
